{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "resolveJsonModule": true
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "reports",
        "videos",
        "history",
        "auth",
        "api-suites",
        "visual-baselines",
        "visual-diffs",
        "inspect-page.ts",
        "inspect-signup.ts",
        "test-signup-direct.ts",
        "debug-tools.ts",
        "playwright-mcp.ts"
    ]
}